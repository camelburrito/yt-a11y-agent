{
  "manifest_version": 3,
  "name": "YouTube A11y Agent (WebMCP)",
  "version": "0.2.0",
  "description": "In-browser accessibility agent for YouTube: WebMCP tools + voice control, with optional on-device Gemini Nano or bring-your-own-key Gemini API. Read-and-act only; never mutates the page or its a11y tree.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": { "service_worker": "service-worker.js" },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube A11y Agent",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "greet": {
      "suggested_key": { "default": "Alt+Shift+A" },
      "description": "Greet me / start the YouTube accessibility agent"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "run_at": "document_idle",
      "world": "MAIN",
      "js": ["agent.js", "provider.js", "agent-control.js"]
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "run_at": "document_idle",
      "world": "ISOLATED",
      "js": ["bridge.js"]
    }
  ]
}

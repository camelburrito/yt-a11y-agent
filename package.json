{
  "name": "yt-a11y-agent",
  "version": "0.1.0",
  "private": true,
  "description": "WebMCP accessibility tool provider + on-device agent for YouTube. The userscripts in src/ have no build step; this package.json exists only for dev tooling (headless selector verification).",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "verify:selectors": "node scripts/verify-selectors.mjs",
    "verify:gestures": "node scripts/verify-gestures.mjs",
    "build:extension": "node scripts/build-extension.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "capture:freeze": "sudo bash scripts/capture-freeze.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camelburrito/yt-a11y-agent.git"
  },
  "devDependencies": {
    "puppeteer-core": "^25.1.0"
  }
}
